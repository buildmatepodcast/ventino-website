# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address that receives all enquiry + service notifications
NOTIFY_EMAIL=ventinowindows@gmail.com

# ─── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────────
# Create a Meta Developer App → Add WhatsApp → get these three values
WHATSAPP_TOKEN=EAAxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# The WhatsApp number to send notifications TO (include country code, no +)
NOTIFY_WHATSAPP_NUMBER=919650670009

# ─── Vercel Blob Storage ───────────────────────────────────────────────────────
# Vercel Dashboard → Storage → Create Blob Store → copy the token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx
